#!/usr/bin/env bash
# give-back pre-push hook — full CI-equivalent check.
# Fires on every `git push`. Runs lint + format-check + tests.
# Bypass: git push --no-verify
set -e

if ! command -v make >/dev/null 2>&1; then
  echo "ERROR: 'make' not found. Cannot run CI check." >&2
  echo "Recover with: git config --unset core.hooksPath  (or use --no-verify)" >&2
  exit 1
fi

exec make ci
